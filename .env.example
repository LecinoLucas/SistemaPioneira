NODE_ENV=development
PORT=3001

# Banco de dados
DATABASE_URL=mysql://<usuario>:<senha>@localhost:3306/estoque_manager

# Segurança de sessão (mínimo 32 caracteres em produção)
JWT_SECRET=<gere_um_segredo_forte_com_32_ou_mais_caracteres>
# OpenID do dono (Google) que deve ser admin automático
OWNER_OPEN_ID=

# Frontend autorizado para CORS (múltiplas URLs separadas por vírgula)
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# Cabeçalhos extras liberados no CORS (opcional)
CORS_ALLOWED_HEADERS=

# Cookies de sessão (opcional)
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SAME_SITE=lax

# Google OAuth (opcional; defina ambos ou nenhum)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Frontend
VITE_API_BASE_URL=http://localhost:3001

# Importação automática de vendas por PDF (opcional)
# Exemplo: /Users/seu-usuario/Documents/pedidos-pdf
SALES_IMPORT_DIR=

# Auditoria (opcional)
# Rotação por tamanho (MB) e retenção de arquivos arquivados (dias)
AUDIT_MAX_SIZE_MB=5
AUDIT_RETENTION_DAYS=30

# Usuários de demonstração local (somente desenvolvimento)
# Deixe em branco para usar os padrões hardcoded (inseguros para produção)
# Em produção use Google OAuth; estes usuários só existem no modo local/demo.
DEMO_ADMIN_PASSWORD=
DEMO_GERENTE_PASSWORD=
DEMO_USER_PASSWORD=

# Estoque V2 (fase 3) - dupla escrita legado + V2
# false: desativado | true: ativa espelhamento para tabelas V2
STOCK_V2_DUAL_WRITE=false

# Estoque V2 (fase 4) - modo de leitura:
# legacy = somente legado | shadow = retorna legado e compara com V2 em log | v2 = usa V2 quando suportado
STOCK_V2_READ_MODE=legacy

# Compatibilidade de rota antiga tRPC (marcas.*):
# true = mantém legado ativo | false = desliga legado e força uso de catalogo.*
LEGACY_MARCAS_ROUTER_ENABLED=true
